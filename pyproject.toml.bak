[build-system]
requires = ["setuptools>=61.0"]
build-backend = "setuptools.build_meta"

[project]
name = "hermes-lite"
version = "0.1.0"
description = "Lightweight Discord bot for Hermes"
requires-python = ">=3.11"
dependencies = [
    "discord.py>=2.4.0,<3",
    "aiohttp>=3.10.0,<4",
]

[project.scripts]
hermes-lite = "hermes_lite:main"
